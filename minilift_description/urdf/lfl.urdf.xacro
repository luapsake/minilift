<?xml version="1.0" encoding="UTF-8"?>
<robot name="lfl" xmlns:xacro="http://ros.org/wiki/xacro">

<!--macro name="lfl" params="*origin"-->



<xacro:macro name="lfl_base" params="prefix">

    <!-- links -->

    <link name="${prefix}_lfl_base">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://minilift_description/meshes/visual/LFL_xyz.stl"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://minilift_description/meshes/collision/LFL_xyz.stl"/>
        </geometry>
      </collision>
    <inertial>
      <origin xyz=".3 0 0" rpy="0 0 0"/>
      <mass value="30"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    </link>

    <link name="${prefix}_lfl_liftplate">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://minilift_description/meshes/visual/LFL_liftplate.stl"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://minilift_description/meshes/collision/LFL_liftplate.stl"/>
        </geometry>
      </collision>
    <inertial>
      <mass value=".3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    </link>

    <joint name="${prefix}_lfl_lift" type="prismatic">
        <origin rpy="0 0 0" xyz="-0.22 0.0 0.0"/>
        <parent link="${prefix}_lfl_liftplate"/>
        <child link="${prefix}_lfl_base"/>
        <axis xyz="0 0 -1"/>
        <limit effort="0" lower="0.15" upper="1.5" velocity="0.05"/>
    </joint>


    <link name="${prefix}_left_wheel_link">
      <visual>
        <origin xyz="0 -0.2625 0" rpy="1.571 0 0"/>
        <geometry>
          <cylinder length="0.005" radius="0.0605"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 -0.2625 0" rpy="1.571 0 0"/>
        <geometry>
          <cylinder length="0.005" radius="0.0605"/>
        </geometry>
      </collision>
    <inertial>
      <mass value=".3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    </link>

    <link name="${prefix}_right_wheel_link">
      <visual>
        <origin xyz="0 0.2625 0" rpy="1.571 0 0"/>
        <geometry>
          <cylinder length="0.005" radius="0.0605"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0.2625 0" rpy="1.571 0 0"/>
        <geometry>
          <cylinder length="0.005" radius="0.0605"/>
        </geometry>
      </collision>
    <inertial>
      <mass value=".3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    </link>

    <joint name="${prefix}_lfl_to_left_wheel" type="continuous">
        <origin rpy="1.571 0 0" xyz="0 0.0 0.0"/>
        <parent link="${prefix}_lfl_base"/>
        <child link="${prefix}_left_wheel_link"/>
    </joint>
 
    <joint name="${prefix}_lfl_to_right_wheel" type="continuous">
        <origin rpy="1.571 0 0" xyz="0 0 0.0"/>
        <parent link="${prefix}_lfl_base"/>
        <child link="${prefix}_right_wheel_link"/>
    </joint>
 
     <gazebo reference="${prefix}_right_wheel_link">
         <mu1 value="1000.0"/>
         <mu2 value="1000.0"/>
         <kp value="10000000.0" />
         <kd value="1.0" />
         <fdr1 value="0 1 0" />
         <material>Gazebo/Grey</material>
     </gazebo>

     <gazebo reference="${prefix}_left_wheel_link">
         <mu1 value="1000.0"/>
         <mu2 value="1000.0"/>
         <kp value="10000000.0" />
         <kd value="1.0" />
         <fdr1 value="0 1 0" />
         <material>Gazebo/Grey</material>
     </gazebo>



</xacro:macro>

<gazebo>
  <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">

    <!-- Plugin update rate in Hz -->
    <updateRate>0</updateRate>

    <!-- Name of left joint, defaults to `left_joint` -->
    <leftJoint>base_link_left_wheel_joint</leftJoint>

    <!-- Name of right joint, defaults to `right_joint` -->
    <rightJoint>base_link_right_wheel_joint</rightJoint>

    <!-- The distance from the center of one wheel to the other, in meters, defaults to 0.34 m -->
    <wheelSeparation>0.5250</wheelSeparation>

    <!-- Diameter of the wheels, in meters, defaults to 0.15 m -->
    <wheelDiameter>0.1210</wheelDiameter>

    <!-- Wheel acceleration, in rad/s^2, defaults to 0.0 rad/s^2 -->
    <wheelAcceleration>1.0</wheelAcceleration>

    <!-- Maximum torque which the wheels can produce, in Nm, defaults to 5 Nm -->
    <wheelTorque>20</wheelTorque>

    <!-- Topic to receive geometry_msgs/Twist message commands, defaults to `cmd_vel` -->
    <commandTopic>cmd_vel</commandTopic>

    <!-- Topic to publish nav_msgs/Odometry messages, defaults to `odom` -->
    <odometryTopic>odom</odometryTopic>

    <!-- Odometry frame, defaults to `odom` -->
    <odometryFrame>odom</odometryFrame>

    <!-- Robot frame to calculate odometry from, defaults to `base_footprint` -->
    <robotBaseFrame>base_footprint</robotBaseFrame>

    <!-- Odometry source, 0 for ENCODER, 1 for WORLD, defaults to WORLD -->
    <odometrySource>1</odometrySource>

    <!-- Set to true to publish transforms for the wheel links, defaults to false -->
    <publishWheelTF>false</publishWheelTF>

    <!-- Set to true to publish transforms for the odometry, defaults to true -->
    <publishOdom>true</publishOdom>

    <!-- Set to true to publish sensor_msgs/JointState on /joint_states for the wheel joints, defaults to false -->
    <publishWheelJointState>false</publishWheelJointState>

    <!-- Set to true to swap right and left wheels, defaults to true -->
    <legacyMode>false</legacyMode>
  </plugin>
</gazebo>

</robot>
