<?xml version="1.0"?>
<robot  xmlns:xacro="http://ros.org/wiki/xacro"
        name="lfl" >


<xacro:macro name="lfl_base" params="prefix">


    <xacro:include filename="$(find minilift_description)/urdf/caster.urdf.xacro" />
    <xacro:include filename="$(find minilift_description)/urdf/wheel.urdf.xacro" />
    <xacro:include filename="$(find minilift_description)/urdf/materials.urdf.xacro" />


    <xacro:arg name="mesh_enabled" default="false" />
    <xacro:arg name="robot_namespace" default="/"/>



    <link   name = "${prefix}_lfl_base">
        <inertial>
            <origin xyz="-0.108 0 -0.02579" rpy="0 0 0"/>
            <mass value="3.978"/>
            <inertia ixx="0.021858680" ixy="0.0" ixz="0.010020353"
                    iyy="0.078572349" iyz="-0.0"
                    izz="0.091971324"/>
        </inertial>
        <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://minilift_description/meshes/visual/LFL_xyz.stl" />
                </geometry>
        </visual>
        <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="package://minilift_description/meshes/visual/LFL_xyz.stl" />
                </geometry>
        </collision>
    </link>


    <link   name =  "${prefix}_base_footprint"/>


    <joint name = "${prefix}_base_joint"  type = "fixed">
        <parent link="${prefix}_base_footprint"/>
        <child link="${prefix}_lfl_base"/>
        <origin xyz="0.0 0.0 0.09188" rpy="0 0 0" />
        <axis xyz="0 1 0" rpy="0 0 0" />
    </joint>

 <!-- LIFTPLATE -->

  <link name="${prefix}_lfl_liftplate">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="package://minilift_description/meshes/visual/LFL_liftplate.stl"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="package://minilift_description/meshes/collision/LFL_liftplate.stl"/>
      </geometry>
    </collision>
  <inertial>
    <mass value="1"/>
    <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
  </inertial>
  </link>

  <gazebo reference="${prefix}_lfl_liftplate">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <joint name="${prefix}_lfl_lift" type="prismatic">
      <origin rpy="0 0 3.14159" xyz="0.22 0.0 1"/>
      <parent link="${prefix}_lfl_base"/>
      <child link="${prefix}_lfl_liftplate"/>
      <axis xyz="0 0 1"/>
      <limit effort="100.0" lower="0.15" upper="0.56" velocity="0.05"/>
      <dynamics damping="0.5" friction="0.06"/>
  </joint>


  <!-- transmissions for Gazebo -->

  <transmission name="${prefix}_lfl_lift_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="${prefix}_lfl_lift">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="${prefix}_lfl_lift_motor">
        <mechanicalReduction>1</mechanicalReduction>
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </actuator>
  </transmission>


    <xacro:caster caster_prefix="rear" parent_link="${prefix}_lfl_base" >
        <origin xyz="-0.20 0.0 -0.02533" rpy="0 0 0" />
    </xacro:caster>


    <xacro:wheel wheel_prefix="left" parent_link="${prefix}_lfl_base" >
        <origin xyz="-0.04 0.14 -0.045" rpy="0 0 0" />
    </xacro:wheel>


    <xacro:wheel wheel_prefix="right" parent_link="${prefix}_lfl_base" >
        <origin xyz="-0.04 -0.14 -0.045" rpy="0 0 0" />
    </xacro:wheel>


    <gazebo>
        <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>$(arg robot_namespace)</robotNamespace>
        <legacyModeNS>true</legacyModeNS>
        </plugin>
    </gazebo>



    


    



</xacro:macro>

</robot>
